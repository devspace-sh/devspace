{
  "name": "devspace-ui",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^1.2.36",
    "@fortawesome/free-brands-svg-icons": "^5.15.4",
    "@fortawesome/free-solid-svg-icons": "^5.15.4",
    "@fortawesome/react-fontawesome": "^0.1.19",
    "@kubernetes/client-node": "^1.0.0",
    "@xterm/addon-attach": "0.12.0",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "get-parameter": "^1.0.8",
    "history": "^4.10.1",
    "isomorphic-unfetch": "^3.1.0",
    "js-sha256": "^0.9.0",
    "js-yaml": "^4.1.1",
    "moment": "^2.30.1",
    "react": "^19.2.6",
    "react-cookie": "^3.1.2",
    "react-dom": "^19.2.6",
    "react-github-btn": "^1.4.0",
    "react-responsive-select": "^4.6.3",
    "react-router": "^6.30.2",
    "react-router-dom": "^6.30.2",
    "react-timeago": "^8.3.0",
    "tslib": "2.8.1"
  },
  "scripts": {
    "start": "NODE_ENV=development NODE_OPTIONS=--openssl-legacy-provider node scripts/start.js",
    "build": "NODE_OPTIONS=--openssl-legacy-provider node scripts/build.js",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\""
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/jest": "^23.3.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^10.17.60",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "8.60.0",
    "@typescript-eslint/parser": "8.60.0",
    "autoprefixer": "10.5.0",
    "css-loader": "3.6.0",
    "dotenv": "4.0.0",
    "dotenv-expand": "4.2.0",
    "eslint": "9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-webpack-plugin": "6.0.0",
    "fork-ts-checker-webpack-plugin": "9.1.0",
    "html-webpack-plugin": "5.6.7",
    "jest": "30.0.0",
    "mini-css-extract-plugin": "2.9.4",
    "postcss-flexbugs-fixes": "5.0.2",
    "postcss-loader": "8.2.1",
    "react-test-renderer": "19.2.6",
    "sass": "1.89.2",
    "sass-loader": "16.0.5",
    "source-map-loader": "5.0.0",
    "style-loader": "4.0.0",
    "terser-webpack-plugin": "^5.3.16",
    "ts-loader": "9.5.7",
    "ts-node": "10.9.2",
    "tsconfig-paths-webpack-plugin": "3.2.0",
    "typescript": "5.9.3",
    "webpack": "5.104.1",
    "webpack-dev-server": "5.2.4",
    "webpack-manifest-plugin": "6.0.1",
    "workbox-webpack-plugin": "7.4.0"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}",
      "!**/*.d.ts"
    ],
    "setupFiles": [
      "<rootDir>/config/polyfills.js",
      "<rootDir>/src/jest.setup.js"
    ],
    "testMatch": [
      "<rootDir>/src/**/__tests__/**/*.(j|t)s?(x)",
      "<rootDir>/src/**/?(*.)(spec|test).(j|t)s?(x)"
    ],
    "testEnvironment": "node",
    "testURL": "http://localhost",
    "transform": {
      "^.+\\.tsx?$": "<rootDir>/config/jest/typescriptTransform.js",
      "^.+\\.css$": "<rootDir>/config/jest/cssTransform.js",
      "^(?!.*\\.(js|jsx|mjs|css|json)$)": "<rootDir>/config/jest/fileTransform.js"
    },
    "transformIgnorePatterns": [
      "[/\\\\]node_modules[/\\\\].+\\.(js|jsx|mjs|ts|tsx)$"
    ],
    "moduleNameMapper": {
      "^react-native$": "react-native-web"
    },
    "moduleFileExtensions": [
      "web.ts",
      "ts",
      "web.tsx",
      "tsx",
      "web.js",
      "js",
      "web.jsx",
      "jsx",
      "json",
      "node",
      "mjs"
    ]
  },
  "browserslist": [
    ">0.5%",
    "last 2 versions",
    "Firefox ESR",
    "not dead",
    "not ie <= 11"
  ],
  "proxy": "http://localhost:8090"
}
